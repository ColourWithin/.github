{
  "name": "@colourwithin/run-oci-cli-command",
  "version": "0.0.0",
  "private": true,
  "description": "ColourWithin GitHub Action for argv-safe OCI CLI command execution.",
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "node scripts/patch-actions-toolkit-exports.mjs && ncc build src/index.ts -o dist --license licenses.txt",
