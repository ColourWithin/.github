  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/io": "^3.0.2",
    "shell-quote": "^1.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/shell-quote": "^1.7.5",
    "@vercel/ncc": "^0.38.4",
    "license-checker-rseidelsohn": "^4.4.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
